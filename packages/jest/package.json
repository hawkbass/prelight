{
  "name": "@prelight/jest",
  "version": "0.0.0",
  "description": "Jest matcher for Prelight. expect(...).toLayout({ ... }).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "tsc -p tsconfig.json",
    "test": "node ./test/run-jest.mjs"
  },
  "peerDependencies": {
    "jest": ">=29"
  },
  "dependencies": {
    "@prelight/core": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "jest",
    "matcher",
    "layout",
    "testing"
  ]
}
