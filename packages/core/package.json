{
  "name": "@prelight/core",
  "version": "0.3.0-rc.1",
  "description": "Framework-agnostic static layout verifier for the web. The core of Prelight.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@napi-rs/canvas": "^0.1.62"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "layout",
    "verification",
    "ci",
    "text-measurement",
    "i18n",
    "testing"
  ]
}
